# =====================================================
# Niajiri Recruitment Platform — Backend Environment
# =====================================================

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3307
DB_NAME=niajiri_platform
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# Prisma connection string built from the values above
DATABASE_URL="mysql://root:your_mysql_password@localhost:3307/niajiri_platform"

# --- Server ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# --- Auth ---
JWT_SECRET=replace_this_with_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
JWT_RESET_SECRET=replace_this_with_another_long_random_secret
JWT_RESET_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=12

# --- File Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# --- Logging ---
LOG_LEVEL=info

# --- Twilio WhatsApp (optional — leave blank to disable) ---
MY_PHONE_NUMBER=whatsapp:+your-phone-number
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
